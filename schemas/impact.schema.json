{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ImpactEnvelope",
  "type": "object",
  "required": [
    "command",
    "payload",
    "schema_version"
  ],
  "properties": {
    "command": {
      "type": "string"
    },
    "payload": {
      "$ref": "#/definitions/ImpactResponse"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "AtlasDiagnostic": {
      "type": "object",
      "required": [
        "code",
        "message",
        "severity"
      ],
      "properties": {
        "code": {
          "$ref": "#/definitions/DiagnosticCode"
        },
        "location": {
          "anyOf": [
            {
              "$ref": "#/definitions/SourceLocation"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/definitions/Severity"
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "AtlasNode": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "provenance",
        "role",
        "title"
      ],
      "properties": {
        "attrs": {
          "default": {},
          "type": "object",
          "additionalProperties": true
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/NodeKind"
        },
        "owns": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathSelector"
          }
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        },
        "role": {
          "$ref": "#/definitions/NodeRole"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": "string"
        },
        "touches": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathSelector"
          }
        }
      }
    },
    "ChangedPath": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "owners": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path": {
          "type": "string"
        }
      }
    },
    "DiagnosticCode": {
      "type": "string",
      "enum": [
        "duplicate_id",
        "broken_reference",
        "malformed_fragment",
        "invalid_id",
        "invalid_edge_endpoint",
        "invalid_path",
        "unknown_node_kind",
        "unknown_edge_kind",
        "scenario_missing_command",
        "scenario_missing_crate",
        "artifact_missing_producer",
        "command_referenced_but_undeclared",
        "invalid_config",
        "discovery_failure",
        "query_root_missing",
        "dead_selector",
        "orphan_node",
        "stale_command",
        "broken_doc_link",
        "duplicate_ownership",
        "empty_fragment",
        "requirement_not_proven",
        "uncovered_crate",
        "active_goal_missing_plan",
        "active_goal_missing_ready_work_items",
        "active_goal_work_item_missing_proof",
        "claim_missing_proof_command",
        "policy_ledger_missing_proof_command"
      ]
    },
    "ImpactHit": {
      "type": "object",
      "required": [
        "node",
        "reason"
      ],
      "properties": {
        "node": {
          "$ref": "#/definitions/AtlasNode"
        },
        "owners": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "ImpactResponse": {
      "type": "object",
      "required": [
        "impacted",
        "uncovered"
      ],
      "properties": {
        "changed_paths": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/ChangedPath"
          }
        },
        "impacted": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ImpactHit"
          }
        },
        "missing_evidence": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/AtlasDiagnostic"
          }
        },
        "scope_warnings": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "suggested_fixes": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "uncovered": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ChangedPath"
          }
        }
      }
    },
    "NodeKind": {
      "type": "string",
      "enum": [
        "requirement",
        "roadmap",
        "proposal",
        "spec",
        "adr",
        "plan",
        "goal",
        "support_tier",
        "policy_ledger",
        "closeout",
        "claim",
        "guide",
        "scenario",
        "fixture",
        "command",
        "artifact",
        "crate",
        "document"
      ]
    },
    "NodeRole": {
      "type": "string",
      "enum": [
        "behavior",
        "proof",
        "document",
        "artifact",
        "command",
        "infra"
      ]
    },
    "PathSelector": {
      "type": "object",
      "required": [
        "pattern"
      ],
      "properties": {
        "pattern": {
          "type": "string"
        }
      }
    },
    "Provenance": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "column": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "fragment": {
          "type": [
            "string",
            "null"
          ]
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "source": {
          "type": "string"
        }
      }
    },
    "Severity": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "info"
      ]
    },
    "SourceLocation": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "column": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "path": {
          "type": "string"
        }
      }
    }
  }
}
