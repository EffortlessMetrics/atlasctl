{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AtlasGraph",
  "type": "object",
  "required": [
    "diagnostics",
    "edges",
    "metrics",
    "nodes",
    "repo",
    "schema_version",
    "tool_version"
  ],
  "properties": {
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/AtlasDiagnostic"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/AtlasEdge"
      }
    },
    "metrics": {
      "$ref": "#/definitions/AtlasMetrics"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/AtlasNode"
      }
    },
    "repo": {
      "$ref": "#/definitions/RepoDescriptor"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "tool_version": {
      "type": "string"
    }
  },
  "definitions": {
    "AtlasDiagnostic": {
      "type": "object",
      "required": [
        "code",
        "message",
        "severity"
      ],
      "properties": {
        "code": {
          "$ref": "#/definitions/DiagnosticCode"
        },
        "location": {
          "anyOf": [
            {
              "$ref": "#/definitions/SourceLocation"
            },
            {
              "type": "null"
            }
          ]
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/definitions/Severity"
        },
        "subject": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "AtlasEdge": {
      "type": "object",
      "required": [
        "from",
        "kind",
        "provenance",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/EdgeKind"
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "AtlasMetrics": {
      "type": "object",
      "required": [
        "diagnostic_count",
        "edge_count",
        "error_count",
        "node_count",
        "warning_count"
      ],
      "properties": {
        "diagnostic_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "edge_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "error_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "node_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "warning_count": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "AtlasNode": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "provenance",
        "role",
        "title"
      ],
      "properties": {
        "attrs": {
          "default": {},
          "type": "object",
          "additionalProperties": true
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/NodeKind"
        },
        "owns": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathSelector"
          }
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        },
        "role": {
          "$ref": "#/definitions/NodeRole"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": "string"
        },
        "touches": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathSelector"
          }
        }
      }
    },
    "DiagnosticCode": {
      "type": "string",
      "enum": [
        "duplicate_id",
        "broken_reference",
        "malformed_fragment",
        "invalid_id",
        "invalid_edge_endpoint",
        "invalid_path",
        "unknown_node_kind",
        "unknown_edge_kind",
        "scenario_missing_command",
        "scenario_missing_crate",
        "artifact_missing_producer",
        "command_referenced_but_undeclared",
        "invalid_config",
        "discovery_failure",
        "query_root_missing",
        "dead_selector",
        "orphan_node",
        "stale_command",
        "broken_doc_link",
        "duplicate_ownership",
        "empty_fragment",
        "requirement_not_proven",
        "uncovered_crate"
      ]
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "explains",
        "proves",
        "uses_fixture",
        "runs_with",
        "emits",
        "exercises",
        "documents",
        "belongs_to",
        "supports",
        "owns_path",
        "touches_path"
      ]
    },
    "NodeKind": {
      "type": "string",
      "enum": [
        "requirement",
        "adr",
        "guide",
        "scenario",
        "fixture",
        "command",
        "artifact",
        "crate",
        "document"
      ]
    },
    "NodeRole": {
      "type": "string",
      "enum": [
        "behavior",
        "proof",
        "document",
        "artifact",
        "command",
        "infra"
      ]
    },
    "PathSelector": {
      "type": "object",
      "required": [
        "pattern"
      ],
      "properties": {
        "pattern": {
          "type": "string"
        }
      }
    },
    "Provenance": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "column": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "fragment": {
          "type": [
            "string",
            "null"
          ]
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "source": {
          "type": "string"
        }
      }
    },
    "RepoDescriptor": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "Severity": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "info"
      ]
    },
    "SourceLocation": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "column": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "path": {
          "type": "string"
        }
      }
    }
  }
}
