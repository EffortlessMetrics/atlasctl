{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WhyEnvelope",
  "type": "object",
  "required": [
    "command",
    "payload",
    "schema_version"
  ],
  "properties": {
    "command": {
      "type": "string"
    },
    "payload": {
      "$ref": "#/definitions/WhyResponse"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "AtlasNode": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "provenance",
        "role",
        "title"
      ],
      "properties": {
        "attrs": {
          "default": {},
          "type": "object",
          "additionalProperties": true
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/definitions/NodeKind"
        },
        "owns": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathSelector"
          }
        },
        "provenance": {
          "$ref": "#/definitions/Provenance"
        },
        "role": {
          "$ref": "#/definitions/NodeRole"
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": "string"
        },
        "touches": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/PathSelector"
          }
        }
      }
    },
    "EdgeKind": {
      "type": "string",
      "enum": [
        "explains",
        "proves",
        "uses_fixture",
        "runs_with",
        "emits",
        "exercises",
        "documents",
        "belongs_to",
        "supports",
        "defines",
        "requires",
        "decides",
        "implements",
        "active_for",
        "claims",
        "governs",
        "closes",
        "supersedes",
        "owns_path",
        "touches_path"
      ]
    },
    "NodeKind": {
      "type": "string",
      "enum": [
        "requirement",
        "roadmap",
        "proposal",
        "spec",
        "adr",
        "plan",
        "goal",
        "support_tier",
        "policy_ledger",
        "closeout",
        "guide",
        "scenario",
        "fixture",
        "command",
        "artifact",
        "crate",
        "document"
      ]
    },
    "NodeRole": {
      "type": "string",
      "enum": [
        "behavior",
        "proof",
        "document",
        "artifact",
        "command",
        "infra"
      ]
    },
    "PathSelector": {
      "type": "object",
      "required": [
        "pattern"
      ],
      "properties": {
        "pattern": {
          "type": "string"
        }
      }
    },
    "Provenance": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "column": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "fragment": {
          "type": [
            "string",
            "null"
          ]
        },
        "line": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "source": {
          "type": "string"
        }
      }
    },
    "TraceDirection": {
      "type": "string",
      "enum": [
        "outgoing",
        "incoming",
        "both"
      ]
    },
    "WhyResponse": {
      "type": "object",
      "required": [
        "chain",
        "root"
      ],
      "properties": {
        "chain": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/WhyStep"
          }
        },
        "root": {
          "$ref": "#/definitions/AtlasNode"
        }
      }
    },
    "WhyStep": {
      "type": "object",
      "required": [
        "direction",
        "node",
        "relationship"
      ],
      "properties": {
        "direction": {
          "$ref": "#/definitions/TraceDirection"
        },
        "node": {
          "$ref": "#/definitions/AtlasNode"
        },
        "relationship": {
          "$ref": "#/definitions/EdgeKind"
        }
      }
    }
  }
}
